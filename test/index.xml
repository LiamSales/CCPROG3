<?xml version="1.0" encoding="UTF-8"?>

<!--
    Import JavaFX layout classes.

    FXML needs imports similarly to Kotlin.
-->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>


<!--
    ROOT CONTAINER

    VBox stacks children vertically.

    Equivalent HTML idea:
    flex-direction: column;
-->
<VBox
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="ui.MainController"

        spacing="20"

        style="
            -fx-background-color: #1e1e1e;
            -fx-padding: 30;
        ">


    <!-- =========================================================
         PAGE TITLE
         ========================================================= -->

    <Label
            text="Vending Machines"

            style="
                -fx-text-fill: white;
                -fx-font-size: 32px;
                -fx-font-weight: bold;
            "
    />


    <!-- =========================================================
         SCROLLABLE MACHINE LIST
         =========================================================

         ScrollPane creates scrollbars automatically.

         Equivalent HTML idea:
         overflow-x: scroll;
    -->
    <ScrollPane

            fitToHeight="true"

            hbarPolicy="AS_NEEDED"
            vbarPolicy="NEVER"

            pannable="true"

            style="
                -fx-background: transparent;
                -fx-background-color: transparent;
            "
    >


        <!-- =====================================================
             HORIZONTAL CONTAINER

             HBox arranges children side-by-side.

             Equivalent HTML:
             display: flex;
             flex-direction: row;
             ===================================================== -->
        <content>

            <HBox spacing="20">


                <!-- =================================================
                     MACHINE CARD
                     ================================================= -->

                <VBox

                        prefWidth="220"
                        spacing="10"

                        style="
                            -fx-background-color: #2b2b2b;
                            -fx-background-radius: 15;
                            -fx-padding: 20;
                        "
                >

                    <Label
                            text="Machine 1"

                            style="
                                -fx-text-fill: white;
                                -fx-font-size: 20px;
                                -fx-font-weight: bold;
                            "
                    />

                    <Label
                            text="12 items available"

                            style="
                                -fx-text-fill: #cfcfcf;
                            "
                    />

                    <Button
                            text="Open"

                            style="
                                -fx-background-color: #4cafef;
                                -fx-text-fill: white;
                                -fx-background-radius: 10;
                            "
                    />

                </VBox>



                <!-- =================================================
                     MACHINE CARD
                     ================================================= -->

                <VBox

                        prefWidth="220"
                        spacing="10"

                        style="
                            -fx-background-color: #2b2b2b;
                            -fx-background-radius: 15;
                            -fx-padding: 20;
                        "
                >

                    <Label
                            text="Machine 2"

                            style="
                                -fx-text-fill: white;
                                -fx-font-size: 20px;
                                -fx-font-weight: bold;
                            "
                    />

                    <Label
                            text="8 items available"

                            style="
                                -fx-text-fill: #cfcfcf;
                            "
                    />

                    <Button
                            text="Open"

                            style="
                                -fx-background-color: #4cafef;
                                -fx-text-fill: white;
                                -fx-background-radius: 10;
                            "
                    />

                </VBox>



                <!-- =================================================
                     CREATE MACHINE CARD
                     ================================================= -->

                <VBox

                        alignment="CENTER"

                        prefWidth="220"
                        spacing="15"

                        style="
                            -fx-background-color: #343434;
                            -fx-background-radius: 15;
                            -fx-padding: 20;
                        "
                >

                    <!--
                        Large plus button.
                    -->
                    <Button

                            text="+"

                            prefWidth="80"
                            prefHeight="80"

                            style="
                                -fx-background-color: #57c76f;
                                -fx-text-fill: white;
                                -fx-font-size: 32px;
                                -fx-font-weight: bold;
                                -fx-background-radius: 100;
                            "
                    />

                    <Label

                            text="Create Machine"

                            style="
                                -fx-text-fill: white;
                                -fx-font-size: 16px;
                            "
                    />

                </VBox>


            </HBox>

        </content>

    </ScrollPane>

</VBox>