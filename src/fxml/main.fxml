<?xml version="1.0" encoding="UTF-8"?>

<VBox spacing="15" alignment="CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.MainController">
      <!-- VBox = vertical layout container
           fx:controller = connects this UI to MainController class -->

    <Label text="Vending Machines"
           style="-fx-font-size: 24px; -fx-font-weight: bold;" />


    <ListView fx:id="machineList"
              prefHeight="200"
              prefWidth="250"/>
    <!-- fx:id links this element to controller field
         prefHeight/Width are layout hints (not absolute size) -->

    <HBox spacing="10" alignment="CENTER">
        <!-- HBox = horizontal container -->

        <Button text="Create Machine"
                onAction="#handleCreate"/>
        <!-- onAction calls controller method via reflection -->

        <Button text="Open Machine"
                onAction="#handleOpen"/>
    </HBox>

</VBox>